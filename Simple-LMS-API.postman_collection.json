							],
							"path": [
								"courses"
							],
							"query": [
								{
									"key": "search",
									"value": "",
									"description": "Cari berdasarkan nama kursus",
									"disabled": true
								},
								{
									"key": "price",
									"value": "",
									"description": "Filter harga exact",
									"disabled": true
								},
								{
									"key": "sort_by",
									"value": "id",
									"description": "id | name | price | -price"
								},
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "per_page",
									"value": "5"
								}
							]
						},
						"description": "Endpoint publik. Parameter search & price sengaja di-disable (uncheck) secara default karena kalau dikirim kosong (?price=) akan error 422 — itu sudah saya benerin di server, tapi best practice tetap uncheck dulu param yang tidak dipakai, baru centang & isi kalau memang mau filter."
