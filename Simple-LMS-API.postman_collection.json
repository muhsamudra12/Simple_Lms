{
	"info": {
		"_postman_id": "lms-academy-uas-collection",
		"name": "Simple LMS API v2 - UAS",
		"description": "Koleksi Postman untuk menguji REST API Simple LMS (Proyek UAS - Pemrograman Sisi Server). Token JWT otomatis tersimpan ke variable {{jwt_token}} setiap kali request Login berhasil dijalankan, jadi tidak perlu copy-paste manual ke request lain.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000/api/v2",
			"type": "string"
		},
		{
			"key": "jwt_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "sample_teacher_id",
			"value": "1",
			"type": "string"
		},
		{
			"key": "sample_course_id",
			"value": "1",
			"type": "string"
		},
		{
			"key": "sample_student_id",
			"value": "2",
			"type": "string"
		},
		{
			"key": "my_user_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "my_course_id",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"postman_user\",\n  \"fullname\": \"Postman Tester\",\n  \"email\": \"postman@test.com\",\n  \"password\": \"rahasia123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"register"
							]
						},
						"description": "Daftar user baru. Jalankan ini SEKALI saja (kalau username sudah ada, akan dapat respons 400)."
					},
					"response": []
				},
				{
					"name": "Login (otomatis simpan token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const data = pm.response.json();",
									"    pm.collectionVariables.set('jwt_token', data.token);",
									"    pm.collectionVariables.set('my_user_id', data.user_id);",
									"    console.log('JWT token & user_id tersimpan (my_user_id =', data.user_id, ')');",
									"} else {",
									"    console.log('Login gagal, token tidak diupdate');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"postman_user\",\n  \"password\": \"rahasia123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Login dan dapatkan token JWT. Tab 'Tests' di request ini otomatis menyimpan token ke variable {{jwt_token}} supaya semua request lain (yang butuh auth) bisa langsung pakai tanpa copy manual."
					},
					"response": []
				}
			]
		},
		{
